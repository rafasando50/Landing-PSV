<section id="inicio" class="intro-section">
  <!-- Dynamic blurred background particles for high-end styling -->
  <div class="glow-particle glow-1"></div>
  <div class="glow-particle glow-2"></div>

  <div class="container intro-container">
    <div class="intro-content">
      <h1 class="intro-title animate-fade-in">
        Innovación y Confiabilidad en Control de Procesos
      </h1>
      <p class="intro-lead animate-fade-in">
        PSV Industrial ofrece un portafolio integral diseñado para cubrir sus
        necesidades técnicas y operativas, garantizando soluciones de
        mantenimiento y suministros que impulsan la eficiencia y seguridad de su
        empresa.
      </p>
      <div class="intro-actions animate-fade-in">
        <a href="#servicios-productos" class="btn btn-accent">Ver Servicios</a>
        <a href="#contacto" class="btn btn-outline-primary">Contáctanos</a>
      </div>
    </div>

    <!-- Value pillars -->
    <div class="intro-grid">
      <div class="value-card">
        <div class="value-icon-container">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="value-icon"
          >
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
          </svg>
        </div>
        <h3 class="value-title">Suministro Certificado</h3>
        <p class="value-text">
          Acceso directo a equipos industriales de marcas líderes como ICOSO,
          Stafsjö y OleumTech, garantizando instrumentación de alta gama y
          válvulas de alto desempeño.
        </p>
      </div>


      <div class="value-card">
        <div class="value-icon-container">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="value-icon"
          >
            <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
            <polyline points="2 17 12 22 22 17"></polyline>
            <polyline points="2 12 12 17 22 12"></polyline>
          </svg>
        </div>
        <h3 class="value-title">Ingeniería y Asesoría</h3>
        <p class="value-text">
          Evaluamos y optimizamos sus procesos mediante asesoría experta en
          selección de equipos, implementación de mejoras operativas y
          capacitación especializada.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-section {
    position: relative;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0.8)),
      url("/industrial-hero-bg.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding-top: 10rem;
    padding-bottom: 7rem;
    overflow: hidden;
    color: var(--text-primary);
    border-bottom: 1px solid var(--dark-border);
  }

  /* Decorative Glow Particles */
  .glow-particle {
    position: absolute;
    border-radius: var(--radius-full);
    filter: blur(120px);
    opacity: 0.15;
    z-index: 1;
    pointer-events: none;
  }

  .glow-1 {
    top: 15%;
    left: 10%;
    width: 300px;
    height: 300px;
    background-color: var(--primary);
    opacity: 0.08;
  }

  .glow-2 {
    bottom: 20%;
    right: 5%;
    width: 350px;
    height: 350px;
    background-color: var(--accent);
    opacity: 0.08;
  }

  .intro-container {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .intro-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .badge {
    background-color: rgba(89, 93, 96, 0.1);
    color: var(--accent);
    border: 1px solid rgba(89, 93, 96, 0.2);
    padding: 0.35rem 1rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .intro-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .intro-lead {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2.25rem;
    line-height: 1.7;
    max-width: 580px;
  }

  .intro-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Value Cards */
  .value-card {
    background: var(--white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    transition: all var(--transition-normal);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .value-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 3px;
    background-color: var(--primary);
    transform: scaleY(0);
    transition: transform var(--transition-normal);
    transform-origin: bottom;
  }

  .value-card:hover {
    transform: translateX(8px);
    background: var(--white);
    border-color: rgba(6, 122, 119, 0.15);
    box-shadow: var(--shadow-md);
  }

  .value-card:hover::before {
    transform: scaleY(1);
    transform-origin: top;
  }

  .value-card:nth-child(2)::before {
    background-color: var(--accent);
  }

  .value-icon-container {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background-color: rgba(6, 122, 119, 0.12);
    border: 1px solid rgba(6, 122, 119, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin-bottom: 1.25rem;
    transition: all var(--transition-normal);
  }

  .value-card:nth-child(2) .value-icon-container {
    background-color: rgba(89, 93, 96, 0.1);
    border-color: rgba(89, 93, 96, 0.2);
    color: var(--accent);
  }

  .value-card:hover .value-icon-container {
    transform: scale(1.1);
  }

  .value-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .value-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Responsive Design */
  @media (max-width: 992px) {
    .intro-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .intro-title {
      font-size: 2.75rem;
    }

    .intro-content {
      align-items: center;
      text-align: center;
    }

    .intro-lead {
      margin-left: auto;
      margin-right: auto;
    }

    .intro-actions {
      justify-content: center;
    }

    .value-card:hover {
      transform: translateY(-5px);
    }

    .value-card::before {
      height: 3px;
      width: 100%;
      top: auto;
      bottom: 0;
      transform: scaleX(0);
      transform-origin: left;
    }

    .value-card:hover::before {
      transform: scaleX(1);
    }
  }

  @media (max-width: 480px) {
    .intro-title {
      font-size: 2.25rem;
    }
    .intro-actions {
      width: 100%;
      flex-direction: column;
    }
    .intro-actions .btn {
      width: 100%;
    }
  }
</style>
