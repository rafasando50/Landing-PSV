---

---

<section id="contacto" class="section section-dark contact-section">
  <!-- Glowing particle backdrop -->
  <div class="contact-glow"></div>

  <div class="container contact-container">
    <!-- Left Card: Contact Information -->
    <div class="contact-info-card">
      <div class="info-card-header">
        <span class="info-subtitle">Contacto Directo</span>
        <h3 class="info-title">¿Listo para comenzar su proyecto?</h3>
        <p class="info-text">
          Póngase en contacto con nuestro equipo de ingenieros para recibir
          asesoría técnica especializada, cotizaciones de equipos o agendar
          servicios de calibración y mantenimiento en planta.
        </p>
      </div>

      <div class="contact-methods">
        <!-- Address -->
        <div class="method-item">
          <div class="method-icon-box">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="method-details">
            <span class="method-label">Dirección</span>
            <span class="method-value"
              >Bernardo Simonin 207, Col. Procoro Alor CP- 96570 Coatzacoalcos,
              Veracruz.
            </span>
          </div>
        </div>

        <!-- Phone -->
        <div class="method-item">
          <div class="method-icon-box">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
          </div>
          <div class="method-details">
            <span class="method-label">Teléfonos</span>
            <a href="tel:+525512345678" class="method-value hover-link"
              >+52 921 362 8217</a
            >
          </div>
        </div>

        <!-- Email -->
        <div class="method-item">
          <div class="method-icon-box">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="method-details">
            <span class="method-label">Correo Electrónico</span>
            <a
              href="mailto:ventas@psvindustrial.com.mx"
              class="method-value hover-link">ventas1@psvindustrial.mx</a
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Right Card: Form -->
    <div class="contact-form-card">
      <h3 class="form-title">Enviar Mensaje de Contacto</h3>
      <p class="form-desc">
        Complete el siguiente formulario y un ingeniero de ventas se comunicará
        con usted a la brevedad.
      </p>

      <form id="landing-contact-form" class="contact-form">
        <input
          type="hidden"
          name="access_key"
          value="3cc54d7a-6f61-4d4d-9cbd-2772d0707acd"
        />
        <div class="form-row">
          <div class="form-group">
            <label for="form-name">Nombre Completo *</label>
            <input
              type="text"
              id="form-name"
              name="name"
              required
              placeholder="Escriba su nombre completo"
              class="form-input"
            />
          </div>
          <div class="form-group">
            <label for="form-company">Empresa *</label>
            <input
              type="text"
              id="form-company"
              name="company"
              required
              placeholder="Nombre de su empresa"
              class="form-input"
            />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="form-email">Correo Electrónico *</label>
            <input
              type="email"
              id="form-email"
              name="email"
              required
              placeholder="ejemplo@empresa.com"
              class="form-input"
            />
          </div>
          <div class="form-group">
            <label for="form-phone">Teléfono de Contacto</label>
            <input
              type="tel"
              id="form-phone"
              name="phone"
              placeholder="10 dígitos con clave lada"
              class="form-input"
            />
          </div>
        </div>

        <div class="form-group">
          <label for="form-message">Mensaje / Requerimiento Técnico *</label>
          <textarea
            id="form-message"
            name="message"
            rows="5"
            required
            placeholder="Describa brevemente las válvulas, equipos de medición o servicios de mantenimiento requeridos..."
            class="form-textarea"></textarea>
        </div>

        <button
          type="submit"
          class="btn btn-accent btn-submit"
          id="form-submit-btn"
        >
          <span>Enviar Mensaje</span>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="submit-arrow"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>

        <div class="form-status" id="form-status-message"></div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    background-color: var(--dark);
    overflow: hidden;
    border-bottom: 1px solid var(--dark-border);
  }

  .contact-glow {
    position: absolute;
    top: 50%;
    left: -10%;
    width: 400px;
    height: 400px;
    background-color: rgba(6, 122, 119, 0.08);
    border-radius: var(--radius-full);
    filter: blur(120px);
    pointer-events: none;
    z-index: 1;
  }

  .contact-container {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 4rem;
    align-items: stretch;
  }

  /* Left Side: Info Card */
  .contact-info-card {
    background: linear-gradient(
      145deg,
      var(--dark-light) 0%,
      rgba(6, 122, 119, 0.1) 100%
    );
    border: 1px solid var(--dark-border);
    border-radius: var(--radius-md);
    padding: 3rem;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .info-card-header {
    margin-bottom: 2.5rem;
  }

  .info-subtitle {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.5rem;
    display: block;
  }

  .info-title {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
    line-height: 1.25;
  }

  .info-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin-top: auto; /* Pushes the contact methods to the bottom if there is extra height */
  }

  .method-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .method-icon-box {
    width: 44px;
    height: 44px;
    background-color: rgba(89, 93, 96, 0.08);
    border: 1px solid rgba(89, 93, 96, 0.2);
    border-radius: var(--radius-sm);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .method-details {
    display: flex;
    flex-direction: column;
  }

  .method-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .method-value {
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.5;
  }

  .hover-link {
    transition: color var(--transition-fast);
  }

  .hover-link:hover {
    color: var(--accent);
  }

  .method-note {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 0.15rem;
  }

  /* Right Side: Form Card */
  .contact-form-card {
    background: var(--white);
    border: 1px solid var(--dark-border);
    border-radius: var(--radius-md);
    padding: 3rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-md);
  }

  .form-title {
    font-size: 1.75rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .form-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 2.25rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .form-input,
  .form-textarea {
    background: var(--white);
    border: 1px solid #cbd5e1;
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    padding: 0.85rem 1rem;
    font-size: 0.95rem;
    transition: all var(--transition-normal);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-muted);
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--primary);
    background: var(--white);
    box-shadow: 0 0 0 3px rgba(6, 122, 119, 0.15);
  }

  .form-textarea {
    resize: vertical;
  }

  .btn-submit {
    align-self: flex-start;
    padding: 0.875rem 2.25rem;
  }

  .submit-arrow {
    transition: transform var(--transition-normal);
  }

  .btn-submit:hover .submit-arrow {
    transform: translateX(4px);
  }

  /* Status message styles */
  .form-status {
    font-size: 0.95rem;
    border-radius: var(--radius-sm);
    transition: all var(--transition-normal);
    opacity: 0;
    display: none;
  }

  .form-status.success {
    display: block;
    opacity: 1;
    background: #ecfdf5;
    border: 1px solid #a7f3d0;
    color: #047857;
    padding: 1rem;
  }

  .form-status.error {
    display: block;
    opacity: 1;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #b91c1c;
    padding: 1rem;
  }

  /* Responsive Styling */
  @media (max-width: 992px) {
    .contact-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .contact-info-card,
    .contact-form-card {
      padding: 1.5rem;
    }

    .btn-submit {
      width: 100%;
    }
  }
</style>

<script>
  // Dynamic client-side form validation and simulated email sender
  const contactForm = document.getElementById(
    "landing-contact-form",
  ) as HTMLFormElement | null;
  const statusMessage = document.getElementById("form-status-message");
  const submitBtn = document.getElementById(
    "form-submit-btn",
  ) as HTMLButtonElement | null;

  if (contactForm && statusMessage && submitBtn) {
    contactForm.addEventListener("submit", (e) => {
      e.preventDefault();

      // Disable button during submit
      submitBtn.disabled = true;
      const originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = "<span>Enviando...</span>";

      // Capture form values
      const formData = new FormData(contactForm);
      const name = formData.get("name");
      const company = formData.get("company");

      // Web3Forms AJAX Submission
      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData,
      })
        .then(async (response) => {
          const json = await response.json();
          if (response.ok) {
            // Show success alert
            statusMessage.className = "form-status success";
            statusMessage.innerHTML = `<strong>¡Muchas gracias, ${name}!</strong> Hemos recibido la solicitud para la empresa <em>${company}</em>. Un especialista técnico se pondrá en contacto contigo en breve.`;
            // Reset form
            contactForm.reset();
          } else {
            console.error(json);
            statusMessage.className = "form-status error";
            statusMessage.innerHTML = `<strong>Error:</strong> ${json.message || "No se pudo enviar el mensaje. Intente de nuevo."}`;
          }
        })
        .catch((error) => {
          console.error(error);
          statusMessage.className = "form-status error";
          statusMessage.innerHTML = "<strong>Error:</strong> Hubo un problema de conexión al enviar el mensaje.";
        })
        .finally(() => {
          // Reset button
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;

          // Clear message after 8 seconds
          setTimeout(() => {
            statusMessage.style.opacity = "0";
            setTimeout(() => {
              statusMessage.className = "form-status";
              statusMessage.style.opacity = "1";
              statusMessage.innerHTML = "";
            }, 300);
          }, 8000);
        });
    });
  }
</script>
