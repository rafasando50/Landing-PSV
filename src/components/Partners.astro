---

---

<section id="marcas-aliadas" class="section section-light partners-section">
  <div class="container">
    <div class="section-header">
      <span class="section-subtitle">Alianzas Estratégicas</span>
      <h2 class="section-title">Nuestras Marcas Aliadas</h2>
      <p class="section-desc">
        Colaboramos con los fabricantes más importantes a nivel internacional
        para suministrar componentes que resistan las condiciones operativas más
        severas.
      </p>
    </div>

    <!-- Highlighted Partner: ICOSO -->
    <div class="icoso-spotlight">
      <div class="spotlight-badge">Calidad</div>
      <div class="spotlight-grid">
        <!-- Left: Logo & Certifications -->
        <div class="spotlight-left">
          <div class="icoso-brand-box">
            <!-- Simulated ICOSO Logo -->
            <div class="icoso-logo-graphic">
              <!-- Safety valve symbol -->
              <svg
                width="60"
                height="60"
                viewBox="0 0 100 100"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M50 15V85M30 35H70M30 65H70M40 35V65M60 35V65"
                  stroke="#ef4444"
                  stroke-width="6"
                  stroke-linecap="round"></path>
                <circle cx="50" cy="50" r="10" fill="#ef4444"></circle>
                <rect x="20" y="25" width="60" height="10" rx="3" fill="#1e293b"
                ></rect>
                <rect x="20" y="65" width="60" height="10" rx="3" fill="#1e293b"
                ></rect>
              </svg>
            </div>
            <div class="icoso-brand-text">
              <span class="icoso-title">VALVULAS E INSTRUMENTOS</span>
              <span class="icoso-name">ICOSO S.A. de C.V.</span>
            </div>
          </div>

          <div class="spotlight-certifications">
            <div class="cert-card-pj">
              <div class="pj-flag">
                <span class="flag-star">★</span>
                <span class="flag-star">★</span>
                <span class="flag-star">★</span>
              </div>
              <div class="pj-content">
                <div class="pj-cert-name">PERRY JOHNSON REGISTRARS, INC.</div>
                <div class="pj-cert-standard">ISO 9001:2015</div>
                <div class="pj-cert-status">
                  Sistema de Gestión de la Calidad Certificado
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Text details -->
        <div class="spotlight-right">
          <h3 class="spotlight-title">
            Distribuidor Autorizado y Centro de Servicio
          </h3>
          <p class="spotlight-desc">
            Establecemos una alianza estratégica clave con <strong
              >ICOSO S.A. de C.V.</strong
            >, fabricante líder en el mercado nacional con certificación
            internacional de calidad. Esta sinergia nos permite ofrecer válvulas
            de seguridad y alivio con tiempos de entrega inigualables y soporte
            directo de fábrica.
          </p>

          <div class="spotlight-features">
            <div class="spot-feat-item">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="spot-icon"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span
                >Válvulas reguladoras, de alivio y fire protection
                personalizadas.</span
              >
            </div>
            <div class="spot-feat-item">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="spot-icon"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span
                >Calibración oficial y mantenimiento bajo normas de fábrica.</span
              >
            </div>
            <div class="spot-feat-item">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="spot-icon"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span
                >Garantía de fábrica extendida en todos los suministros.</span
              >
            </div>
          </div>

          <a href="#contacto" class="btn btn-primary">Solicitar Equipos ICOSO</a
          >
        </div>
      </div>
    </div>

    <!-- Brands Grid -->
    <div class="brands-subheading">
      Más Marcas Aliadas en Nuestro Portafolio
    </div>
    <div class="brands-grid">
      <!-- Brand 1: Stafsjö -->
      <div class="brand-logo-card stafsjo-theme">
        <div class="brand-logo-top">
          <span class="brand-label-s">Stafsjö</span>
          <span class="brand-est">SINCE 1666</span>
        </div>
        <div class="brand-hover-content">Suecia • Válvulas de Guillotina</div>
      </div>

      <!-- Brand 2: EBRO ARMATUREN -->
      <div class="brand-logo-card">
        <span class="brand-name-bold font-ebro">EBRO ARMATUREN</span>
        <div class="brand-hover-content">Alemania • Válvulas de Mariposa</div>
      </div>

      <!-- Brand 3: IMI -->
      <div class="brand-logo-card">
        <div class="brand-logo-imi">
          <span class="imi-circle"></span>
          <span class="font-imi">IMI</span>
        </div>
        <div class="brand-hover-content">
          Reino Unido • Soluciones de Control de Fluidos
        </div>
      </div>

      <!-- Brand 4: FLV -->
      <div class="brand-logo-card">
        <span class="font-flv">FLV Industrial Valves</span>
        <div class="brand-hover-content">EE.UU. • Válvulas Industriales</div>
      </div>

      <!-- Brand 5: AMS LATAM -->
      <div class="brand-logo-card">
        <span class="font-ams">AMS LATAM</span>
        <div class="brand-hover-content">
          Latinoamérica • Sistemas de Monitoreo
        </div>
      </div>

      <!-- Brand 6: OleumTech -->
      <div class="brand-logo-card">
        <span class="font-oleum">OleumTech</span>
        <div class="brand-hover-content">
          EE.UU. • Instrumentación Inalámbrica
        </div>
      </div>

      <!-- Brand 7: ARI ARMATUREN -->
      <div class="brand-logo-card">
        <span class="font-ari">ARI ARMATUREN</span>
        <div class="brand-hover-content">
          Alemania • Válvulas de Aislamiento y Control
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .partners-section {
    background-color: var(--light);
    border-bottom: 1px solid var(--dark-border);
  }

  /* ICOSO Spotlight Card styling */
  .icoso-spotlight {
    background: var(--white);
    border: 1px solid var(--dark-border);
    border-top: 5px solid var(--accent);
    border-radius: var(--radius-md);
    padding: 3rem;
    box-shadow: var(--shadow-md);
    position: relative;
    margin-bottom: 4.5rem;
    overflow: hidden;
  }

  .spotlight-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background-color: rgba(89, 93, 96, 0.1);
    color: var(--accent);
    border: 1px solid rgba(89, 93, 96, 0.2);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .spotlight-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 3.5rem;
    align-items: center;
  }

  /* ICOSO Brand info */
  .icoso-brand-box {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .icoso-logo-graphic {
    background: var(--light);
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }

  .icoso-brand-text {
    display: flex;
    flex-direction: column;
  }

  .icoso-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }

  .icoso-name {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--text-primary);
    line-height: 1.2;
  }

  /* Perry Johnson Certificate simulation */
  .spotlight-certifications {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cert-card-pj {
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    position: relative;
  }

  .pj-flag {
    display: flex;
    flex-direction: column;
    background: #0284c7;
    color: var(--white);
    padding: 0.5rem;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: bold;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    box-shadow: var(--shadow-sm);
  }

  .flag-star {
    line-height: 0.9;
  }

  .pj-content {
    display: flex;
    flex-direction: column;
  }

  .pj-cert-name {
    font-size: 0.75rem;
    font-weight: 800;
    color: #44403c;
    letter-spacing: 0.02em;
  }

  .pj-cert-standard {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #0c4a6e;
    margin: 0.15rem 0;
  }

  .pj-cert-status {
    font-size: 0.7rem;
    color: #78716c;
  }

  /* Right content details */
  .spotlight-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .spotlight-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .spotlight-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .spotlight-features {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .spot-feat-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .spot-icon {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* Other Brands grid */
  .brands-subheading {
    text-align: center;
    font-size: 1.2rem;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    position: relative;
  }

  .brands-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  /* Individual Brand Logo Cards */
  .brand-logo-card {
    background: var(--white);
    border: 1px solid var(--dark-border);
    border-radius: var(--radius-sm);
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    transition: all var(--transition-normal);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .brand-logo-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary);
  }

  .brand-hover-content {
    position: absolute;
    bottom: -100%;
    left: 0;
    width: 100%;
    background: var(--primary);
    color: var(--white);
    font-size: 0.75rem;
    text-align: center;
    padding: 0.5rem;
    font-weight: 600;
    transition: bottom var(--transition-normal);
  }

  .brand-logo-card:hover .brand-hover-content {
    bottom: 0;
  }

  /* Stylized Logos */
  .brand-logo-top {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .brand-label-s {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    color: #064e3b;
    line-height: 1;
  }

  .brand-est {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    font-weight: 700;
    margin-top: 0.2rem;
  }

  .font-ebro {
    font-family: sans-serif;
    font-weight: 900;
    font-size: 1.15rem;
    color: #1e3a8a;
    letter-spacing: -0.02em;
  }

  .brand-logo-imi {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .imi-circle {
    width: 14px;
    height: 14px;
    background-color: #6b21a8;
    border-radius: var(--radius-full);
  }

  .font-imi {
    font-weight: 800;
    font-size: 1.4rem;
    color: #581c87;
  }

  .font-flv {
    font-family: var(--font-heading);
    font-weight: 800;
    font-style: italic;
    font-size: 1.1rem;
    color: #0369a1;
  }

  .font-ams {
    font-weight: 800;
    font-size: 1.15rem;
    color: #0f766e;
    letter-spacing: 0.05em;
  }

  .font-oleum {
    font-weight: 800;
    font-size: 1.3rem;
    color: #1d4ed8;
  }

  .font-ari {
    border-top: 3px double #1d4ed8;
    border-bottom: 3px double #1d4ed8;
    padding: 0.15rem 0.5rem;
    font-weight: 700;
    color: #1d4ed8;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  /* Responsive styling */
  @media (max-width: 992px) {
    .spotlight-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 480px) {
    .icoso-spotlight {
      padding: 1.5rem;
    }

    .icoso-brand-box {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .spotlight-title {
      font-size: 1.3rem;
    }
  }
</style>
