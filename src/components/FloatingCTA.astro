---
// Floating Call To Action component
---

<a
  href="#marcas-aliadas"
  id="floating-icoso-cta"
  class="floating-cta"
  aria-label="Ver ICOSO"
>
  <div class="cta-pulse-ring"></div>
  <div class="cta-content">
    <div class="cta-icon-box">
      <!-- Custom Valve/Safety Shield Icon -->
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        <polyline points="9 11 11 13 15 9"></polyline>
      </svg>
    </div>
    <span class="cta-text">ICOSO</span>
  </div>
</a>

<style>
  .floating-cta {
    position: fixed;
    bottom: 2.5rem;
    right: 2.5rem;
    z-index: 99;
    background: linear-gradient(135deg, #067a77 0%, #034a48 100%);
    border: 2px solid #595d60; /* Highlight gold/accent border */
    border-radius: var(--radius-full);
    padding: 0.75rem 1.5rem;
    box-shadow: 0 10px 25px rgba(6, 122, 119, 0.4);
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    text-decoration: none;
    color: var(--white);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .floating-cta:hover {
    transform: translateY(-5px) scale(1.03);
    box-shadow:
      0 15px 30px rgba(6, 122, 119, 0.5),
      0 0 15px rgba(89, 93, 96, 0.3);
    border-color: var(--white);
  }

  .cta-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    z-index: 2;
  }

  .cta-icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: transform 0.4s ease;
  }

  .floating-cta:hover .cta-icon-box {
    transform: rotate(360deg);
  }

  .cta-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Pulse animation ring */
  .cta-pulse-ring {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: var(--radius-full);
    border: 2px solid rgba(89, 93, 96, 0.5);
    animation: cta-pulse 2s infinite;
    z-index: 1;
    pointer-events: none;
  }

  @keyframes cta-pulse {
    0% {
      transform: scale(0.95);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.4;
    }
    100% {
      transform: scale(1.25);
      opacity: 0;
    }
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .floating-cta {
      bottom: 1.5rem;
      right: 1.5rem;
      padding: 0.6rem 1.2rem;
    }
    .cta-text {
      font-size: 0.8rem;
    }
  }
</style>

