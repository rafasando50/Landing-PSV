<section id="servicios-productos" class="section section-dark catalog-section">
  <div class="container">
    <div class="section-header">
      <span class="section-subtitle">Catálogo Profesional</span>
      <h2 class="section-title">Nuestros Servicios y Productos</h2>
      <p class="section-desc">
        Ofrecemos un portafolio integral diseñado para cubrir sus necesidades
        técnicas y operativas, garantizando soluciones de alta eficiencia y
        seguridad.
      </p>
    </div>

    <!-- Category Filter Controls -->
    <div class="catalog-filters">
      <button class="filter-btn" data-filter="all">Todos</button>
      <button class="filter-btn" data-filter="servicios">Servicios</button>
      <button class="filter-btn" data-filter="mantenimiento"
        >Mantenimiento Especializado</button
      >
      <button class="filter-btn active" data-filter="icoso">ICOSO</button>
      <button class="filter-btn" data-filter="stafsjo">Stafsjö</button>
      <button class="filter-btn" data-filter="oleumtech">OleumTech</button>
      <button class="filter-btn" data-filter="ams">AMSLATAM</button>
      <button class="filter-btn" data-filter="armaturen">ARI ARMATUREN</button>
    </div>

    <!-- Catalog Grid -->
    <div class="catalog-grid">
      <!-- CARD 1: Suministro de Equipos (Servicio PSV) -->
      <div
        class="catalog-item servicios animate-fade-in"
        data-category="servicios"
      >
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <div class="catalog-card-body">
            <span class="item-tag">Servicio General</span>
            <h3 class="item-title">Suministro de Equipos Industriales</h3>
            <p class="item-desc">
              Distribución oficial de instrumentación, válvulas y refacciones
              adaptadas a las condiciones de su planta.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span>Válvulas industriales en diversas aleaciones.</span>
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Sistemas de instrumentación y medición de alta precisión.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span>Equipos especializados bajo pedido del cliente.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CARD 2: Mantenimiento Industrial (Servicio PSV) -->
      <div
        class="catalog-item servicios animate-fade-in"
        data-category="servicios"
      >
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <div class="catalog-card-body">
            <span class="item-tag">Servicio General</span>
            <h3 class="item-title">Mantenimiento Industrial</h3>
            <p class="item-desc">
              Mantenimiento correctivo y preventivo de equipos de control de
              flujo en talleres certificados.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span
                  >Calibración de instrumentos de medición (p, t, f, l).</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Reparación de válvulas de seguridad, control (globo) y
                  manuales.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span>Prueba hidrostática y certificación de hermeticidad.</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CARD 3: Ingeniería y Asesoría (Servicio PSV) -->
      <div
        class="catalog-item servicios animate-fade-in"
        data-category="servicios"
      >
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <div class="catalog-card-body">
            <span class="item-tag">Servicio General</span>
            <h3 class="item-title">Ingeniería y Asesoría Técnica</h3>
            <p class="item-desc">
              Estudios de ingeniería y dimensionamiento técnico para optimizar
              la seguridad e integridad del proceso.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span>Selección idónea de válvulas y actuadores.</span>
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Evaluación de procesos e implementación de mejoras
                  operativas.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span>Capacitación especializada para su personal técnico.</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CARD 4A: Válvulas de Seguridad y Alivio (ICOSO) -->
      <div class="catalog-item icoso animate-fade-in" data-category="icoso">
        <div class="catalog-card highlight-card">
          <div class="card-accent-bar accent-bar"></div>
          <div class="catalog-card-body">
            <div class="brand-header">
              <span class="item-tag tag-icoso">ICOSO</span>
              <span class="brand-slogan">Socio Autorizado</span>
            </div>
            <h3 class="item-title text-gold">Válvulas de Seguridad y Alivio</h3>
            <p class="item-desc">
              Válvulas de relevo de presión robustas diseñadas y fabricadas bajo
              estrictos estándares internacionales para la protección de
              recipientes y tuberías.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Diseños operados por resorte y asistidos por piloto para
                  gases, vapores y líquidos.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Cumplimiento con normas y estándares internacionales de
                  seguridad industrial.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Fabricación en materiales de alta resistencia: Bronce, Acero
                  al Carbón y Acero Inoxidable.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                Mantenimiento y calibración certificada con tiempos de entrega líderes.
              </li>
            </ul>

            <!-- Certificate Sello -->
            <div class="certificate-badge">
              <div class="cert-icon">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 11 11 13 15 9"></polyline>
                </svg>
              </div>
              <div class="cert-text">
                <span class="cert-title">ISO 9001:2015</span>
                <span class="cert-body">Perry Johnson Registrars, Inc.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CARD 4B: Válvulas Reguladoras y Admisoras (ICOSO) -->
      <div class="catalog-item icoso animate-fade-in" data-category="icoso">
        <div class="catalog-card highlight-card">
          <div class="card-accent-bar accent-bar"></div>
          <div class="catalog-card-body">
