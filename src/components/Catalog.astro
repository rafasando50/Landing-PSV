            <div class="certificate-badge">
              <div class="cert-icon">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 11 11 13 15 9"></polyline>
                </svg>
              </div>
              <div class="cert-text">
                <span class="cert-title">ISO 9001:2015</span>
                <span class="cert-body">Perry Johnson Registrars, Inc.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

