---

<section id="servicios-productos" class="section section-dark catalog-section">
  <div class="container">
    <div class="section-header">
      <span class="section-subtitle">Catálogo Profesional</span>
      <h2 class="section-title">Nuestros Servicios y Productos</h2>
      <p class="section-desc">
        Ofrecemos un portafolio integral diseñado para cubrir sus necesidades
        técnicas y operativas, garantizando soluciones de alta eficiencia y
        seguridad.
      </p>
    </div>

    <!-- Category Filter Controls -->
    <div class="catalog-filters">
      <button class="filter-btn" data-filter="all">Todos</button>
      <button class="filter-btn" data-filter="servicios">Servicios</button>
      <button class="filter-btn active" data-filter="icoso">ICOSO</button>
      <button class="filter-btn" data-filter="stafsjo">Stafsjö</button>
      <button class="filter-btn" data-filter="oleumtech">OleumTech</button>
      <button class="filter-btn" data-filter="ams">AMSLATAM</button>
      <button class="filter-btn" data-filter="armaturen">ARI ARMATUREN</button>
    </div>

    <!-- Catalog Grid -->
    <div class="catalog-grid">
      <!-- CARD 1: Suministro de Equipos (Servicio PSV) -->
      <div
        class="catalog-item servicios animate-fade-in"
        data-category="servicios"
      >
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/suministro-equipos.png" alt="Suministro de Equipos Industriales" class="card-image" />
            <div class="card-image-placeholder placeholder-servicios">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="placeholder-text">PSV Industrial</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <span class="item-tag">Servicio General</span>
            <h3 class="item-title">Suministro de Equipos Industriales</h3>
            <p class="item-desc">
              Distribución oficial de instrumentación, válvulas y refacciones
              adaptadas a las condiciones de su planta.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span>Válvulas industriales en diversas aleaciones.</span>
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Sistemas de instrumentación y medición de alta precisión.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span>Equipos especializados bajo pedido del cliente.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CARD 2: Mantenimiento Industrial (Servicio PSV) -->
      <div
        class="catalog-item servicios animate-fade-in"
        data-category="servicios"
      >
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/mantenimiento-industrial.png" alt="Mantenimiento Industrial" class="card-image" />
            <div class="card-image-placeholder placeholder-servicios">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="placeholder-text">PSV Industrial</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <span class="item-tag">Servicio General</span>
            <h3 class="item-title">Mantenimiento Industrial</h3>
            <p class="item-desc">
              Mantenimiento correctivo y preventivo de equipos de control de
              flujo en talleres certificados.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span
                  >Calibración de instrumentos de medición (p, t, f, l).</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Reparación de válvulas de seguridad, control (globo) y
                  manuales.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span>Prueba hidrostática y certificación de hermeticidad.</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CARD 3: Ingeniería y Asesoría (Servicio PSV) -->
      <div
        class="catalog-item servicios animate-fade-in"
        data-category="servicios"
      >
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/ingenieria-asesoria.png" alt="Ingeniería y Asesoría Técnica" class="card-image" />
            <div class="card-image-placeholder placeholder-servicios">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="placeholder-text">PSV Industrial</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <span class="item-tag">Servicio General</span>
            <h3 class="item-title">Ingeniería y Asesoría Técnica</h3>
            <p class="item-desc">
              Estudios de ingeniería y dimensionamiento técnico para optimizar
              la seguridad e integridad del proceso.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span>Selección idónea de válvulas y actuadores.</span>
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Evaluación de procesos e implementación de mejoras
                  operativas.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span>Capacitación especializada para su personal técnico.</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- CARD 4A: Válvulas de Seguridad y Alivio (ICOSO) -->
      <div class="catalog-item icoso animate-fade-in" data-category="icoso">
        <div class="catalog-card highlight-card">
          <div class="card-accent-bar accent-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/valvulas-seguridad-icoso.png" alt="Válvulas de Seguridad y Alivio ICOSO" class="card-image" />
            <div class="card-image-placeholder placeholder-icoso">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
              <span class="placeholder-text">ICOSO</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <div class="brand-header">
              <span class="item-tag tag-icoso">ICOSO</span>
              <span class="brand-slogan">Socio Autorizado</span>
            </div>
            <h3 class="item-title text-gold">Válvulas de Seguridad y Alivio</h3>
            <p class="item-desc">
              Válvulas de relevo de presión robustas diseñadas y fabricadas bajo
              estrictos estándares internacionales para la protección de
              recipientes y tuberías.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Diseños operados por resorte y asistidos por piloto para
                  gases, vapores y líquidos.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Cumplimiento con normas y estándares internacionales de
                  seguridad industrial.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Fabricación en materiales de alta resistencia: Bronce, Acero
                  al Carbón y Acero Inoxidable.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                Mantenimiento y calibración certificada con tiempos de entrega líderes.
              </li>
            </ul>

            <!-- Certificate Sello -->
            <div class="certificate-badge">
              <div class="cert-icon">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 11 11 13 15 9"></polyline>
                </svg>
              </div>
              <div class="cert-text">
                <span class="cert-title">ISO 9001:2015</span>
                <span class="cert-body">Perry Johnson Registrars, Inc.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CARD 4B: Válvulas Reguladoras y Admisoras (ICOSO) -->
      <div class="catalog-item icoso animate-fade-in" data-category="icoso">
        <div class="catalog-card highlight-card">
          <div class="card-accent-bar accent-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/valvulas-reguladoras-icoso.png" alt="Válvulas Reguladoras y Admisoras ICOSO" class="card-image" />
            <div class="card-image-placeholder placeholder-icoso">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
              <span class="placeholder-text">ICOSO</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <div class="brand-header">
              <span class="item-tag tag-icoso">ICOSO</span>
              <span class="brand-slogan">Control de Presión</span>
            </div>
            <h3 class="item-title text-gold">
              Válvulas Reguladoras y Admisoras
            </h3>
            <p class="item-desc">
              Dispositivos auto-operados diseñados para el control preciso y
              constante de la presión y el caudal de fluidos en sistemas de
              distribución.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Válvulas reductoras y sostenedoras de presión de acción
                  directa y alta precisión.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Válvulas admisoras y eliminadoras de aire y vacío para
                  protección de tuberías.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Construcción robusta para soportar variaciones severas de
                  presión en la red.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Calibración y ajuste en fábrica bajo parámetros técnicos del
                  cliente.</span
                >
              </li>
            </ul>

            <!-- Certificate Sello -->
            <div class="certificate-badge">
              <div class="cert-icon">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 11 11 13 15 9"></polyline>
                </svg>
              </div>
              <div class="cert-text">
                <span class="cert-title">ISO 9001:2015</span>
                <span class="cert-body">Perry Johnson Registrars, Inc.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CARD 4C: Sistemas Fire Protection y Agua (ICOSO) -->
      <div class="catalog-item icoso animate-fade-in" data-category="icoso">
        <div class="catalog-card highlight-card">
          <div class="card-accent-bar accent-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/sistemas-contra-incendio-icoso.png" alt="Sistemas Fire Protection y Agua ICOSO" class="card-image" />
            <div class="card-image-placeholder placeholder-icoso">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
              <span class="placeholder-text">ICOSO</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <div class="brand-header">
              <span class="item-tag tag-icoso">ICOSO</span>
              <span class="brand-slogan">Fire Protection</span>
            </div>
            <h3 class="item-title text-gold">
              Sistemas Fire Protection y Agua
            </h3>
            <p class="item-desc">
              Soluciones especializadas y certificadas para redes de protección
              contra incendios y sistemas de infraestructura hidráulica crítica.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Válvulas de alivio para arranque de bombas contra incendio
                  según normas del sector.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Válvulas de control y sostenimiento de nivel para tanques de
                  almacenamiento.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Pruebas hidrostáticas individuales certificadas que
                  garantizan hermeticidad total.</span
                >
              </li>
              <li>
                <span class="list-bullet accent-bullet"></span>
                <span
                  >Operación fiable e inmediata en escenarios de respuesta ante
                  emergencias.</span
                >
              </li>
            </ul>

            <!-- Certificate Sello -->
            <div class="certificate-badge">
              <div class="cert-icon">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                  <polyline points="9 11 11 13 15 9"></polyline>
                </svg>
              </div>
              <div class="cert-text">
                <span class="cert-title">ISO 9001:2015</span>
                <span class="cert-body">Perry Johnson Registrars, Inc.</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CARD 5: Productos EBRO ARMATUREN & Stafsjö (Stafsjö) -->
      <div class="catalog-item stafsjo animate-fade-in" data-category="stafsjo">
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/valvulas-mariposa-ebro.png" alt="Válvulas de Mariposa EBRO" class="card-image" />
            <div class="card-image-placeholder placeholder-stafsjo">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14M19 8l-3 4 3 4M5 8l3 4-3 4" />
                <circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="placeholder-text">EBRO ARMATUREN</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <span class="item-tag tag-stafsjo">EBRO ARMATUREN</span>
            <h3 class="item-title">Válvulas de Mariposa EBRO</h3>
            <p class="item-desc">
              Válvulas de mariposa de alta calidad para control, aislamiento y
              aplicaciones de procesos químicos e industriales severos.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span>Válvulas de mariposa con asiento blando.</span>
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Válvulas de mariposa recubiertas con PTFE/PFA para fluidos
                  corrosivos.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Válvulas de mariposa de alto rendimiento y triple
                  excentricidad.</span
                >
              </li>
              <li>
                <span class="list-bullet"></span>
                <span
                  >Tecnología en actuadores neumáticos y automatización.</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="catalog-item stafsjo animate-fade-in" data-category="stafsjo">
        <div class="catalog-card">
          <div class="card-accent-bar primary-bar"></div>
          <!-- Contenedor de Imagen de Producto -->
          <div class="card-image-container">
            <img src="/images/catalog/valvulas-guillotina-stafsjo.png" alt="Válvulas de Guillotina Stafsjö" class="card-image" />
            <div class="card-image-placeholder placeholder-stafsjo">
              <div class="placeholder-glow"></div>
              <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14M19 8l-3 4 3 4M5 8l3 4-3 4" />
                <circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="placeholder-text">Stafsjö</span>
            </div>
          </div>
          <div class="catalog-card-body">
            <span class="item-tag tag-stafsjo">Stafsjö</span>
            <h3 class="item-title">Válvulas de Guillotina Stafsjö</h3>
            <p class="item-desc">
              Líderes suecos desde 1666 en válvulas de guillotina para el manejo
              de pulpa, papel, minería y tratamiento de agua.
            </p>
            <ul class="item-list">
              <li>
                <span class="list-bullet"></span>
                <span
                  >Válvulas de guillotina para fluidos abrasivos o pulpas
