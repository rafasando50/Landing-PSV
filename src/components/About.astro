---

---

<section id="sobre-nosotros" class="section section-light about-section">
  <div class="container">
    <div class="about-grid">
      <!-- Left side: Graphical card / Brand representation -->
      <div class="about-graphics">
        <div class="graphics-card">
          <div class="card-inner">
            <h2 class="graphics-title">
              Ingeniería que Impulsa a la Industria
            </h2>
            <p class="graphics-desc">
              Desde nuestra fundación, nos hemos dedicado a proveer soluciones
              que garanticen la continuidad y optimización de los procesos
              industriales de nuestros clientes.
            </p>

            <div class="stats-grid">
              <div class="stat-item">
                <span class="stat-number" id="stat-years">10+</span>
                <span class="stat-label">Años de Experiencia</span>
              </div>
              <div class="stat-item">
                <span class="stat-number" id="stat-valves">10k+</span>
                <span class="stat-label">Equipos Suministrados</span>
              </div>
            </div>

            <div class="iso-badge-small">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                class="iso-icon"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              <span>Certificaciones Internacionales de Calidad</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right side: Tab switcher -->
      <div class="about-content">
        <div class="about-tabs-header">
          <button class="tab-btn active" data-tab="nosotros"
            >Sobre Nosotros</button
          >
          <button class="tab-btn" data-tab="mision">Misión</button>
          <button class="tab-btn" data-tab="vision">Visión</button>
          <button class="tab-btn" data-tab="proposito">Propósito</button>
        </div>

        <div class="about-tabs-content">
          <!-- Nosotros Tab -->
          <div class="tab-pane active" id="tab-nosotros">
            <h3 class="tab-pane-title">Quiénes Somos</h3>
            <p class="tab-pane-text">
              <strong>PSV Industrial S.A. de C.V.</strong> es una empresa mexicana
              especializada en suministro de equipos, mantenimiento industrial e ingeniería
              de procesos. Atendemos los sectores energético, petroquímico, manufacturero
              y minero con un portafolio que incluye válvulas de todos los tipos,
              instrumentación, tuberías y servicios de calibración bajo <strong
                >NOM-093-SCFI-2020</strong
              >.
            </p>
            <p class="tab-pane-text">
              Trabajamos tanto en sitio como en nuestras instalaciones, con el
              respaldo de aliados de clase mundial como <strong>
                ICOSO, EBRO, ARI, OleumTech y FLV Industrial Valves, entre
                otros.
              </strong>
            </p>
            <ul class="features-list">
              <li>
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--primary)"
                  stroke-width="3"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                >
                <span
                  >Taller de servicio con herramientas de calibración de alta
                  precisión.</span
                >
              </li>
              <li>
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--primary)"
                  stroke-width="3"
                  ><polyline points="20 6 9 17 4 12"></polyline></svg
                >
                <span
                  >Distribución exclusiva de marcas consolidadas en el mercado
                  global.</span
                >
              </li>
            </ul>
          </div>

          <!-- Misión Tab -->
          <div class="tab-pane" id="tab-mision">
            <h3 class="tab-pane-title">Nuestra Misión</h3>
            <p class="tab-pane-text text-highlight">
              "Proveer soluciones integrales de suministro industrial y
              mantenimiento técnico especializado, garantizando productos
              certificados, tiempos de respuesta ágiles y un servicio confiable
              que proteja la continuidad operativa de cada cliente."
            </p>
            <p class="tab-pane-text">
              Nos comprometemos a brindar un asesoramiento técnico de excelencia
              y una respuesta ágil a las necesidades operativas de la industria
              mexicana, manteniendo los estándares de calidad más elevados
              mediante personal altamente calificado y alianzas estratégicas con
              marcas de prestigio mundial.
            </p>
          </div>

          <!-- Visión Tab -->
          <div class="tab-pane" id="tab-vision">
            <h3 class="tab-pane-title">Nuestra Visión</h3>
            <p class="tab-pane-text text-highlight">
              "Ser el aliado estratégico de referencia nacional en mantenimiento
              y suministro de materiales industriales, reconocidos por nuestra
              capacidad de respuesta, rigor técnico y compromiso con la
              seguridad y el éxito de las operaciones de nuestros clientes."
            </p>
            <p class="tab-pane-text">
              Buscamos expandir nuestra cobertura de servicios, innovar
              constantemente en tecnologías de monitoreo industrial e
              instrumentación wireless, y mantener una mejora continua alineada
              a las regulaciones nacionales e internacionales de seguridad
              industrial.
            </p>
          </div>

          <!-- Propósito Tab -->
          <div class="tab-pane" id="tab-proposito">
            <h3 class="tab-pane-title">Nuestro Propósito</h3>
            <p class="tab-pane-text text-highlight">
              "Mantener los procesos industriales funcionando con seguridad,
              eficiencia y confiabilidad porque cada válvula, cada instrumento y
              cada intervención técnica que realizamos protege vidas, activos y
              operaciones críticas."
            </p>
            <p class="tab-pane-text">
              Creemos firmemente en el poder de la ingeniería de precisión para
              transformar y proteger. Nuestro propósito es proveer valor a largo
              plazo mediante soluciones que no solo resuelvan retos inmediatos
              de control y calibración, sino que promuevan la eficiencia
              energética y la integridad de las infraestructuras de nuestros
              clientes.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    background-color: var(--light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  /* Graphics Card styling */
  .about-graphics {
    position: relative;
  }

  .graphics-card {
    background: linear-gradient(
      135deg,
      var(--primary) 0%,
      var(--primary-hover) 100%
    );
    border-radius: var(--radius-lg);
    padding: 3rem;
    color: var(--white);
    box-shadow: var(--shadow-xl);
    position: relative;
    overflow: hidden;
  }

  .graphics-card::after {
    content: "";
    position: absolute;
    bottom: -50px;
    right: -50px;
    width: 200px;
    height: 200px;
    background: rgba(184, 151, 83, 0.15);
    border-radius: var(--radius-full);
    z-index: 1;
  }

  .card-inner {
    position: relative;
    z-index: 2;
  }

  .badge-about {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    color: var(--accent-light);
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.25rem 0.85rem;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .graphics-title {
    color: var(--white);
    font-size: 2rem;
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .graphics-desc {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-size: 2.25rem;
    font-family: var(--font-heading);
    font-weight: 800;
    color: white;
  }

  .stat-label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .iso-badge-small {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    background: rgba(0, 0, 0, 0.15);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
  }

  .iso-icon {
    color: white;
    flex-shrink: 0;
  }

  /* Tabs switcher styling */
  .about-content {
    display: flex;
    flex-direction: column;
  }

  .about-tabs-header {
    display: flex;
    border-bottom: 2px solid var(--dark-border);
    margin-bottom: 2.5rem;
    gap: 1.5rem;
  }

  .tab-btn {
    background: none;
    border: none;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-secondary);
    padding: 0.75rem 0.25rem;
    cursor: pointer;
    position: relative;
    transition: all var(--transition-fast);
  }

  .tab-btn::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 3px;
    background-color: var(--primary);
    transition: width var(--transition-normal);
  }

  .tab-btn:hover {
    color: var(--primary);
  }

  .tab-btn.active {
    color: var(--primary);
  }

  .tab-btn.active::after {
    width: 100%;
  }

  /* Tab content panel */
  .about-tabs-content {
    position: relative;
  }

  .tab-pane {
    display: none;
    animation: tabFade 0.5s ease-in-out forwards;
  }

  .tab-pane.active {
    display: block;
  }

  @keyframes tabFade {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tab-pane-title {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
    color: var(--primary);
  }

  .tab-pane-text {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }

  .tab-pane-text.text-highlight {
    font-size: 1.2rem;
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--text-primary);
    border-left: 4px solid var(--accent);
    padding-left: 1.25rem;
    margin-bottom: 1.5rem;
    font-style: italic;
    line-height: 1.6;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .features-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .features-list li svg {
    flex-shrink: 0;
  }

  /* Responsive Design */
  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  @media (max-width: 480px) {
    .graphics-card {
      padding: 1.5rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .about-tabs-header {
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .tab-btn {
      font-size: 0.95rem;
      padding: 0.5rem 0.1rem;
    }
  }
</style>

<script>
  // About section Tab switcher logic
  const tabButtons = document.querySelectorAll(".tab-btn");
  const tabPanes = document.querySelectorAll(".tab-pane");

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      // Remove active class from all buttons and panes
      tabButtons.forEach((btn) => btn.classList.remove("active"));
      tabPanes.forEach((pane) => pane.classList.remove("active"));

      // Add active class to clicked button
      button.classList.add("active");

      // Get target tab id and show it
      const targetId = button.getAttribute("data-tab");
      const targetPane = document.getElementById(`tab-${targetId}`);
      if (targetPane) {
        targetPane.classList.add("active");
      }
    });
  });
</script>
